{
  "name": "workspace",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "db:generate": "turbo  db:generate",
    "db:push": "turbo  db:push",
    "db:studio": "cd packages/database && pnpm db:studio",
    "type-check": "turbo type-check",
    "tsc": "turbo type-check",
    "test": "turbo test",
    "test:e2e": "turbo test:e2e",
    "lint:api": "cd apps/api && pnpm run lint",
    "lint:web": "cd apps/web && pnpm run lint",
    "version:ci": "changeset version && pnpm install --no-frozen-lockfile"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@eslint/js": "^10.0.1",
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "@types/react": "~19.2.14",
    "@types/react-dom": "~19.2.3",
    "dotenv-cli": "^11.0.0",
    "eslint": "10.1.0",
    "globals": "^17.5.0",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "turbo": "^2.9.5",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.58.1"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22"
  },
  "pnpm": {
    "overrides": {
      "keyv": "5.5.4"
    },
    "peerDependencyRules": {
      "ignoreMissing": [
        "eslint",
        "react"
      ],
      "allowedVersions": {
        "eslint": "10",
        "react": "19"
      }
    }
  }
}
