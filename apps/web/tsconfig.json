{
  "extends": "@repo/typescript-config/base.json",
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@repo/ui/components/*": [
        "../../packages/ui/src/components/*"
      ],
      "@repo/ui/lib/*": [
        "../../packages/ui/src/lib/*"
      ],
      "@repo/ui/hooks/*": [
        "../../packages/ui/src/hooks/*"
      ],
      "@repo/ui/*": [
        "../../packages/ui/src/*"
      ],
      "@/components/ui/*": [
        "../../packages/ui/src/components/*"
      ],
      "@/components/layout/*": [
        "../../packages/ui/src/layout/*"
      ],
      "@/components/features/calls/*": [
        "./src/components/features/calls/*"
      ],
      "@/components/features/chat/video-call-content": [
        "./src/components/features/chat/video-call-content"
      ],
      "@/components/features/chat/video-call": [
        "./src/components/features/chat/video-call"
      ],
      "@/components/features/*": [
        "../../packages/ui/src/features/*"
      ],
      "@/components/shared/info-panel": [
        "./src/components/shared/info-panel"
      ],
      "@/components/shared/*": [
        "../../packages/ui/src/shared/*"
      ],
      "@repo/shared": [
        "../../packages/shared/index.ts"
      ],
      "@repo/shared/*": [
        "../../packages/shared/src/*"
      ]
    },
    "types": [
      "node"
    ]
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
